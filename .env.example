# ─── Database ───────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/blogforge

# ─── Auth (NextAuth) ────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# ─── Super Admin (created by `npm run seed`) ────────────────
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=Site Administrator

# ─── Cloudinary (image storage) ────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Public unsigned upload preset (optional, for client uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ─── Google Gemini (AI features) ───────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Email (Gmail SMTP via Nodemailer) ─────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM_NAME=BlogForge

# ─── Public site config ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=BlogForge
NEXT_PUBLIC_GA_ID=
